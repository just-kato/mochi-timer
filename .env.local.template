# ============================================================
# .env.local.template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# Supabase — Found at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database — Found at: supabase.com → your project → Settings → Database
# Transaction mode (port 6543) for runtime, session mode (port 5432) for migrations
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Resend — Found at: resend.com → API Keys
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cron — Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
